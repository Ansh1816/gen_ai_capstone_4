flowchart TB
    User([Clinic Operations Staff]):::user

    subgraph UI["Streamlit UI — app.py"]
        direction LR
        T1["Tab 1<br/>Single Patient Analysis"]:::ui
        T2["Tab 2<br/>Batch Analysis"]:::ui
        T3["Tab 3<br/>AI Care Coordinator"]:::ui
    end

    subgraph ML["ML Prediction Layer — model_brain.py"]
        direction LR
        Scaler["StandardScaler<br/>scaler.pkl"]:::ml
        Model["DecisionTreeClassifier<br/>max_depth=10<br/>model.pkl"]:::ml
        Feats["14 features<br/>feature_cols.pkl"]:::ml
        Scaler --> Model
        Feats -.-> Scaler
    end

    subgraph AG["Agentic Layer — LangGraph"]
        direction TB
        subgraph SG["5-Step StateGraph (agent.py)"]
            direction LR
            S1["1·risk_assessment<br/><i>ML</i>"]:::agent
            S2["2·risk_reasoning<br/><i>LLM</i>"]:::agent
            S3["3·guideline_retrieval<br/><i>RAG</i>"]:::agent
            S4["4·intervention_plan<br/><i>LLM</i>"]:::agent
            S5["5·report_generation<br/><i>LLM</i>"]:::agent
            S1 --> S2 --> S3 --> S4 --> S5
        end
        RA["ReAct Agent<br/>chatbot_agent.py<br/>(predict_noshow + search_guidelines tools)"]:::agent
    end

    subgraph RAG["RAG Layer"]
        direction LR
        Docs[("guidelines/*.md<br/>5 policy documents")]:::rag
        Build["build_vectorstore.py<br/>RecursiveCharacterTextSplitter<br/>chunk=500 · overlap=80"]:::rag
        Embed["sentence-transformers<br/>all-MiniLM-L6-v2 (384-d)"]:::rag
        Chroma[("ChromaDB<br/>40 chunks · persisted")]:::rag
        Docs --> Build --> Embed --> Chroma
    end

    LLM["Groq Cloud<br/>llama-3.1-8b-instant<br/>(free tier)"]:::external
    PDF["Structured PDF Report<br/>pdf_generator.py (fpdf2)"]:::out

    User --> UI
    T1 --> ML
    T2 --> ML
    T3 --> SG
    T3 --> RA

    S1 -.-> ML
    S2 -.-> LLM
    S3 -.-> Chroma
    S4 -.-> LLM
    S5 -.-> LLM

    RA -->|tool call| ML
    RA -->|tool call| Chroma
    RA -->|reasoning| LLM

    S5 --> PDF
    T3 --> PDF

    classDef ui fill:#DBEAFE,stroke:#1E40AF,color:#1E3A8A,stroke-width:2px
    classDef ml fill:#FED7AA,stroke:#C2410C,color:#7C2D12,stroke-width:2px
    classDef agent fill:#FECACA,stroke:#B91C1C,color:#7F1D1D,stroke-width:2px
    classDef rag fill:#BBF7D0,stroke:#15803D,color:#14532D,stroke-width:2px
    classDef external fill:#E9D5FF,stroke:#7E22CE,color:#581C87,stroke-width:2px
    classDef out fill:#FEF3C7,stroke:#B45309,color:#78350F,stroke-width:2px
    classDef user fill:#F3F4F6,stroke:#374151,color:#111827,stroke-width:2px
